# =============================================================================
# Backend API Configuration
# =============================================================================
# The URL where your FastAPI backend is running.
#
# Local Development: http://localhost:8000
# Production: https://q4-hackhthon-ii.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# Better Auth Configuration
# =============================================================================
# The URL of this frontend application (used for session management).
#
# Local Development: http://localhost:3000
# Production: https://q4-hackhthon-ii.vercel.app
NEXT_PUBLIC_AUTH_URL=http://localhost:3000

# The base URL for Better Auth endpoints.
# Note: Currently not used - auth endpoints are on the FastAPI backend.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:8000/auth

# =============================================================================
# Setup Instructions
# =============================================================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Update NEXT_PUBLIC_API_URL with your backend URL
# 3. Update NEXT_PUBLIC_AUTH_URL with your frontend URL
# 4. For local development, keep defaults (localhost)
# 5. For production, use actual deployed URLs
# 6. Never commit .env to version control (it's in .gitignore)

# =============================================================================
# Production Environment Variables (Vercel)
# =============================================================================
# When deploying to Vercel, set these in the Vercel dashboard:
#
# NEXT_PUBLIC_API_URL=https://q4-hackhthon-ii.onrender.com
# NEXT_PUBLIC_AUTH_URL=https://q4-hackhthon-ii.vercel.app
